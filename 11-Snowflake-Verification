/*-----------------------------------------------------------------------------
  SECTION 8: Data Quality Checks
-----------------------------------------------------------------------------*/

use role transformer_role;
use database analytics;
use schema staging_marts;

-- check for null values in critical columns
select 'dim_customers_current' as table_name,
       sum(case when customer_id is null then 1 else 0 end) as null_customer_id,
       sum(case when segment is null then 1 else 0 end) as null_segment,
       sum(case when status is null then 1 else 0 end) as null_status
from dim_customers_current;

-- check for duplicates in primary keys
select 
    customer_id,
    count(*) as duplicate_count
from dim_customers_current
group by customer_id
having count(*) > 1;

-- verify fact table grain
select 
    interaction_id,
    count(*) as duplicate_count
from fct_customer_interactions
group by interaction_id
having count(*) > 1;

-- check sentiment score ranges
select 
    min(sentiment_score) as min_sentiment,
    max(sentiment_score) as max_sentiment,
    avg(sentiment_score) as avg_sentiment
from fct_customer_interactions;
-- expected: min = -1.0, max = 1.0

-- check for orphaned records (interactions without customers)
select count(*) as orphaned_interactions
from fct_customer_interactions f
left join dim_customers_current d on f.customer_key = d.customer_key
where d.customer_key is null;
-- expected: 0

