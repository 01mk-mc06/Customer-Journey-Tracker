/*-----------------------------------------------------------------------------
  SECTION 6: Test Security (PII Masking)
-----------------------------------------------------------------------------*/

-- test as analyst role (should see masked data)
use role analyst_role;
use warehouse reporting_wh;
use database analytics;
use schema staging_intermediate;

select 
    customer_id,
    customer_name,  -- should be masked: 'M*** Santos'
    email,          -- should be masked: 'm***@gmail.com'
    phone,          -- should be masked: '+63-***-***-4567'
    segment,
    status
from int_customers_deduplicated
limit 5;

-- verify row access policy (should only see smb and consumer)
select 
    segment,
    count(*) as customer_count
from int_customers_deduplicated
group by segment
order by segment;
-- expected: only 'consumer' and 'smb' (no 'enterprise')

-- switch back to transformer role (should see full data)
use role transformer_role;
use warehouse transforming_wh;
use schema staging_intermediate;

select 
    customer_id,
    customer_name,  -- should be unmasked: full name
    email,          -- should be unmasked: full email
    phone,          -- should be unmasked: full phone
    segment,
    status
from int_customers_deduplicated
limit 5;

-- verify all segments visible (including enterprise)
select 
    segment,
    count(*) as customer_count
from int_customers_deduplicated
group by segment
order by segment;
-- expected: 'consumer', 'enterprise', 'smb'

